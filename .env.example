# Copy to .env and fill in. Both are optional, but at least one is needed
# for LLM-generated briefings or spoken audio.

# OpenAI — drives LLM summaries and is the audio fallback.
OPENAI_API_KEY=

# ElevenLabs — preferred TTS backend (warmer voice). Optional.
ELEVENLABS_API_KEY=

# Override the default ElevenLabs voice ("Rachel"). Optional.
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Override the default ElevenLabs model. Optional.
# ELEVENLABS_MODEL=eleven_turbo_v2_5
